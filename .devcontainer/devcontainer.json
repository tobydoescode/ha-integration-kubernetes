{
  "name": "Home Assistant Kubernetes Integration",
  "image": "ghcr.io/home-assistant/devcontainer:2026.4",
  "forwardPorts": [8123],
  "postCreateCommand": "pip install uv && uv sync --all-extras",
  "mounts": [
    "source=${localWorkspaceFolder}/custom_components/kubernetes,target=/workspaces/config/custom_components/kubernetes,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  }
}
